<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/album_glow.xml -->
<!-- A soft cyan glow layer that sits behind the album art card -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#0060EFFF"/>
    <corners android:radius="28dp"/>
    <!-- CardView's elevation already provides shadow;
         this just adds a faint colored bloom -->
    <stroke android:width="1dp" android:color="#1560EFFF"/>
</shape>