<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/item_song_bg.xml -->
<!-- Subtle glassmorphism card background for each song row -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state — slightly brighter -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#25FFFFFF"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#20FFFFFF"/>
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#12FFFFFF"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#0DFFFFFF"/>
        </shape>
    </item>

</selector>