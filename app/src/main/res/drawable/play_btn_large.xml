<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/play_btn_large.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#9060EFFF"/>
            <stroke android:width="2dp" android:color="#A060EFFF"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#5060EFFF"/>
            <stroke android:width="2dp" android:color="#7060EFFF"/>
        </shape>
    </item>
</selector>