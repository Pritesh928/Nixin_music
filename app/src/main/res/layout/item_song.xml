<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_gradient"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgAlbumArt"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/glass_bg"
            android:contentDescription="Album Art"/>

        <TextView
            android:id="@+id/txtSongTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgAlbumArt"
            android:layout_toStartOf="@id/btnMore"
            android:layout_alignTop="@id/imgAlbumArt"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            android:text="Song Title"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/txtArtistName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgAlbumArt"
            android:layout_toStartOf="@id/btnMore"
            android:layout_below="@id/txtSongTitle"
            android:layout_marginStart="14dp"
            android:layout_marginTop="2dp"
            android:text="Artist"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/ic_menu_more"
            android:background="@android:color/transparent"
            android:tint="#AAAAAA"
            android:contentDescription="More options"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>